#include <Wire.h>
#include <LiquidCrystal_I2C.h>
#include <DHT.h>

#define DHT_PIN 2           // Pin Digital untuk Sensor DHT11
#define DHTTYPE DHT11      

DHT dht(DHT_PIN, DHTTYPE);
LiquidCrystal_I2C lcd(0x27, 16, 2); 

void setup() {
  Serial.begin(9600); 
  dht.begin();
  lcd.init();
  lcd.backlight();
  
  lcd.setCursor(0, 0);
  lcd.print("  DHT MONITORING ");
  lcd.setCursor(0, 1);
  lcd.print("   INITIALIZING ");
  delay(2000);
  lcd.clear();
}

void loop() {
  float kelembapan = dht.readHumidity();
  float suhu = dht.readTemperature();

  if (isnan(kelembapan) || isnan(suhu)) {
    lcd.setCursor(0, 0);
    lcd.print("Error Sensor DHT");
    return; 
  }

  // Tampilan Suhu dan Kelembapan di Baris 1
  lcd.setCursor(0, 0);
  lcd.print("T:");
  lcd.print((int)suhu); 
  lcd.print("C ");
  lcd.print("H:");
  lcd.print((int)kelembapan);
  lcd.print("%   "); 

  lcd.setCursor(0, 1);
  lcd.print("System Status OK");

  delay(1500);
}
